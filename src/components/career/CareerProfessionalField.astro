---
const { field } = Astro.props;
---

<section id="professional-field" class="scroll-mt-32">
    <h3 class="text-2xl font-bold mb-6">Campo de acción</h3>

    <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-white rounded-xl border">
            <h4 class="font-bold mb-2">Oportunidades profesionales</h4>
            <p class="text-sm text-gray-500">{field}</p>
        </div>
    </div>
</section>
