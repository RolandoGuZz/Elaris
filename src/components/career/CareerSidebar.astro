---
const { duration, programDirection } = Astro.props;
---

<aside class="lg:w-1/3">
    <div class="sticky top-8 space-y-6">
        <div class="bg-white rounded-2xl p-6 border">
            <div class="space-y-4">
                <div>
                    <p class="text-xs text-gray-500 uppercase">Duración</p>
                    <p class="font-semibold">{duration}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase">Jefatura Carrera</p>
                    <p class="font-semibold">{programDirection}</p>
                </div>
            </div>

        </div>
    </div>
</aside>
