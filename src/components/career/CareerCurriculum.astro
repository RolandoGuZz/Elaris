---
const { plan } = Astro.props;

const lines = plan.split("\n").map((l: string) => l.trim()).filter(Boolean);

const semesters: { title: string; subjects: string[] }[] = [];
let current: { title: string; subjects: string[] } | null = null;

for (const line of lines) {

  if (line.includes("SEMESTRE")) {

    if (current) semesters.push(current);

    current = {
      title: line,
      subjects: []
    };

  } else {

    current?.subjects.push(line);

  }
}

if (current) semesters.push(current);
---

<section id="curriculum" class="scroll-mt-32">

  <h3 class="text-2xl font-bold mb-6">
    Plan de Estudios
  </h3>

  <div class="space-y-4">

    {semesters.map((semester) => (

      <details class="bg-white border rounded-xl overflow-hidden group">

        <summary class="cursor-pointer flex justify-between items-center p-5 bg-primary/5 font-bold text-primary list-none">

          {semester.title}

          <span class="transition-transform group-open:rotate-180">
            ▼
          </span>

        </summary>

        <div class="p-5 grid md:grid-cols-2 gap-4">

          {semester.subjects.map((subject) => (

            <div class="flex items-start gap-2">

              <span class="text-green-500">✓</span>

              <p class="text-sm font-medium">
                {subject}
              </p>

            </div>

          ))}

        </div>

      </details>

    ))}

  </div>

</section>