---
const { mission, vision, objective } = Astro.props;
---
<section id="overview" class="scroll-mt-32">
    <h3 class="text-2xl font-bold mb-6 text-black">
Descripción del curso
    </h3>

    <div class="prose max-w-none text-gray-600 dark:text-gray-400">
        <div class="mb-6">
            <h4 class="text-lg font-bold mb-2 text-black">Misión</h4>
            <p>{mission}</p>
        </div>

        <div class="mb-6">
            <h4 class="text-lg font-bold mb-2 text-black">Visión</h4>
            <p>{vision}</p>
        </div>

        <div class="mb-6">
            <h4 class="text-lg font-bold mb-2 text-black">Objetivos</h4>
            <p>{objective}</p>
        </div>
    </div>
</section>