---
const { name, description, image } = Astro.props;
---

<section class="relative bg-primary overflow-hidden">
  <div
    class="absolute inset-0 opacity-90 bg-cover bg-center backdrop-blur-xs"
    style={`background-image:url(${image})`}
  ></div>

  <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/85 to-transparent backdrop-blur-sm"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <nav class="flex items-center gap-2 text-white/80 text-sm mb-6">
      <a href="/" class="hover:text-white transition-colors">
        Home
      </a>
      <span>›</span>
      <a href="/catalog" class="hover:text-white transition-colors">
        Catalog
      </a>
      <span>›</span>
      <span class="text-white font-medium">
        {name}
      </span>
    </nav>

    <h1 class="text-4xl md:text-6xl font-black text-white mb-6 drop-shadow-md">
      {name}
    </h1>

    <p class="text-lg md:text-xl text-white/95 max-w-2xl drop-shadow-md">
      {description}
    </p>
  </div>
</section>
