---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
const homeInfo = await getCollection("homeInfo");
const about = homeInfo.find((s) => s.slug === "about");
---

<Layout title="About NovaUniversitas">
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div
            class="aspect-square rounded-2xl overflow-hidden shadow-2xl relative z-10 bg-cover bg-center"
            style={`background-image: url('${about?.data.image}')`}>
          </div>
        </div>

        <div>
          <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-6">
            {about?.data.title}
          </h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            {about?.data.description}
          </p>
          <a
            href="https://www.novauniversitas.edu.mx/web/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#1D7B43] font-bold flex items-center gap-2 hover:underline">
            Conoce nuestra misión →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
