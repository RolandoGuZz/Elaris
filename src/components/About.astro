---
import { getCollection } from "astro:content";
const homeInfo = await getCollection("homeInfo");
const about = homeInfo.find((s) => s.slug === "about");
---

<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <img
          src={about?.data.image}
          alt="Sobre NovaUniversitas"
          role="img"
          aria-label="Estudiantes en NovaUniversitas"
          class="aspect-square rounded-2xl overflow-hidden shadow-2xl relative z-10 w-full object-cover"
          loading="lazy"
        />
      </div>
      <div>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          {about?.data.title}
        </h2>
        <p class="text-slate-600 text-lg leading-relaxed mb-8">
          {about?.data.description}
        </p>
        <a
          href="https://www.novauniversitas.edu.mx/web/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-[#1D7B43] font-semibold hover:underline">
          Conoce nuestra misión
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
