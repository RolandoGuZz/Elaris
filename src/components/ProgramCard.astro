---
import type { CollectionEntry } from "astro:content";

interface Props {
  career: CollectionEntry<"career">;
}

const { career } = Astro.props;
const { data } = career;
---

<article
  class="border border-gray-200 rounded-xl p-6 bg-white hover:shadow-lg hover:-translate-y-1 transition-all duration-200 h-full flex flex-col"
>
  <h3 class="text-xl font-semibold text-gray-900 mb-3">
    {data.name}
  </h3>

  <p class="text-gray-600 leading-relaxed mb-6 flex-1">
    {data.description}
  </p>

  <a
    href={`/catalog/${career.slug}`}
    class="text-blue-600 font-medium inline-flex items-center gap-2 border-t border-gray-100 pt-4 mt-auto hover:text-blue-700 group"
  >
    View Details
    <span class="transform group-hover:translate-x-1 transition-transform"
      >→</span
    >
  </a>
</article>
