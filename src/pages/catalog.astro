---
import Layout from "../layouts/Layout.astro";
import ProgramCard from "../components/ProgramCard.astro";
import { getCollection } from "astro:content";

const careers = await getCollection("career");
---

<Layout title="University Programs | Elaris">
  <main class="max-w-7xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1 class="text-5xl font-bold text-gray-900 mb-4">University</h1>
      <p class="text-xl text-gray-600">
        Explore our {careers.length} academic programs
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {careers.map((career) => <ProgramCard career={career} />)}
    </div>
  </main>
</Layout>
